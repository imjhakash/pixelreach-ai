# ─────────────────────────────────────────────
# Copy this file to .env.local and fill values
# ─────────────────────────────────────────────

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Encryption key for SMTP/IMAP passwords & OpenRouter keys (32 random chars)
ENCRYPTION_KEY=your_32_char_random_secret_here__

# Cron job shared secret (set same value in Hostinger cron PHP files)
CRON_SECRET=your_cron_secret_token

# App base URL (used for tracking pixel & click redirect links in emails)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Optional: Sentry DSN for error tracking (free tier)
SENTRY_DSN=
